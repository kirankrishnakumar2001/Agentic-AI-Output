<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:osi="http://example.org/osi-cisco-bookings-ontology#"
    xml:base="http://example.org/osi-cisco-bookings-ontology">

    <owl:Ontology rdf:about="http://example.org/osi-cisco-bookings-ontology">
        <rdfs:label>Cisco Bookings Enterprise Ontology</rdfs:label>
        <rdfs:comment>Enterprise OWL ontology generated from the provided OSI Semantic Model, SQL star schema, glossary, and Quote-to-Booking business process documentation. Explicit knowledge is derived from fact/dimension semantics. Inferred knowledge is limited to process activity classes, actor ownership, selected inverse properties, disjointness, and conservative cardinality restrictions. Geography key naming mismatch geo_key versus geography_key is documented as a semantic equivalence note rather than a separate class.</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#BusinessEntity">
        <rdfs:label>Business Entity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#ProcessElement">
        <rdfs:label>Process Element</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#BusinessActor">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Business Actor</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#BusinessActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#ProcessElement"/>
        <rdfs:label>Business Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#QuoteToBookingProcess">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#ProcessElement"/>
        <rdfs:label>Quote To Booking Process</rdfs:label>
        <rdfs:comment>Front portion of the Order-to-Cash cycle beginning when a qualified opportunity is ready to transact and ending when a valid customer order is accepted and recognized as a booking, with entitlements and a renewal obligation established.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Booking">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Booking</rdfs:label>
        <rdfs:comment>Stores measurable business transactions representing customer bookings at one row per booked order line.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#occursOnDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#Date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#forCustomer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#Customer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#includesProduct"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#Product"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#assignedToGeography"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#Geography"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#ownedBySalesRepresentative"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#SalesRepresentative"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#governedByContract"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#Contract"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/osi-cisco-bookings-ontology#involvesPartner"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/osi-cisco-bookings-ontology#Partner"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#RenewalBooking">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:label>Renewal Booking</rdfs:label>
        <rdfs:comment>Conservative inferred subclass representing bookings identified as renewals by booking_type or isRenewal flag. Full datatype equivalence is documented but not strictly enforced in OWL DL here.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Date">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Date</rdfs:label>
        <rdfs:comment>Stores calendar and fiscal date information used for analyzing bookings across time periods.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Customer">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>Contains descriptive information about customers who purchase products or services.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Product">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>Contains descriptive information about products and services sold through bookings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Partner">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Partner</rdfs:label>
        <rdfs:comment>Stores information about channel partners involved in selling products.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Geography">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Geography</rdfs:label>
        <rdfs:comment>Provides hierarchical geographic information for analyzing bookings across global regions. Glossary geo_key is treated as semantically equivalent to schema geography_key.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#SalesRepresentative">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Sales Representative</rdfs:label>
        <rdfs:comment>Contains information about sales representatives responsible for customer bookings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Contract">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessEntity"/>
        <rdfs:label>Contract</rdfs:label>
        <rdfs:comment>Stores information describing customer contracts associated with bookings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#OpportunityQualification">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Opportunity Qualification</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#ConfigurePriceQuoteActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Configure Price Quote Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#DealRegistrationActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Deal Registration Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#OrderPlacementActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Order Placement Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#BookingRecognitionActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Booking Recognition Activity</rdfs:label>
        <rdfs:comment>A valid accepted order is booked, booking amount ACV and TCV are computed, and the booking is classified as New Renewal or Upsell.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#FulfillmentProvisioningActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Fulfillment Provisioning Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#ContractEntitlementCreationActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Contract Entitlement Creation Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#RenewalLifecycleActivity">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:label>Renewal Lifecycle Activity</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#SalesAccountExecutive">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Sales Account Executive</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#DealDesk">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Deal Desk</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#RevenueOperations">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Revenue Operations</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#ChannelPartnerOrganization">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Channel Partner Organization</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#CustomerExperienceRenewals">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Customer Experience Renewals</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/osi-cisco-bookings-ontology#Finance">
        <rdfs:subClassOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:label>Finance</rdfs:label>
    </owl:Class>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Booking"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Date"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Customer"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Product"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Partner"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Geography"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#SalesRepresentative"/>
            <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Contract"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#occursOnDate">
        <rdfs:label>occurs on date</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Date"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#hasBookingOnDate"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#hasBookingOnDate">
        <rdfs:label>has booking on date</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Date"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#forCustomer">
        <rdfs:label>for customer</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Customer"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#hasBooking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#hasBooking">
        <rdfs:label>has booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Customer"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#includesProduct">
        <rdfs:label>includes product</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Product"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#isIncludedInBooking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#isIncludedInBooking">
        <rdfs:label>is included in booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Product"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#involvesPartner">
        <rdfs:label>involves partner</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Partner"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#participatesInBooking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#participatesInBooking">
        <rdfs:label>participates in booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Partner"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#assignedToGeography">
        <rdfs:label>assigned to geography</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Geography"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#hasBookingInGeography"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#hasBookingInGeography">
        <rdfs:label>has booking in geography</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Geography"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#ownedBySalesRepresentative">
        <rdfs:label>owned by sales representative</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#SalesRepresentative"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#ownsBooking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#ownsBooking">
        <rdfs:label>owns booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#SalesRepresentative"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#governedByContract">
        <rdfs:label>governed by contract</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Contract"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#governsBooking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#governsBooking">
        <rdfs:label>governs booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Contract"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#partOfProcess">
        <rdfs:label>part of process</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#QuoteToBookingProcess"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#performsActivity">
        <rdfs:label>performs activity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#performedBy"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#performedBy">
        <rdfs:label>performed by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActor"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#precedesActivity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:label>precedes activity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#BusinessActivity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#recognizesBooking">
        <rdfs:label>recognizes booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#BookingRecognitionActivity"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#recognizedByActivity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#recognizedByActivity">
        <rdfs:label>recognized by activity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Booking"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#BookingRecognitionActivity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#createsContract">
        <rdfs:label>creates contract</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#ContractEntitlementCreationActivity"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#Contract"/>
        <owl:inverseOf rdf:resource="http://example.org/osi-cisco-bookings-ontology#createdByActivity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#createdByActivity">
        <rdfs:label>created by activity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#Contract"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#ContractEntitlementCreationActivity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#producesRenewalBooking">
        <rdfs:label>produces renewal booking</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/osi-cisco-bookings-ontology#RenewalLifecycleActivity"/>
        <rdfs:range rdf:resource="http://example.org/osi-cisco-bookings-ontology#RenewalBooking"/>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/osi-cisco-bookings-ontology#bookingId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
