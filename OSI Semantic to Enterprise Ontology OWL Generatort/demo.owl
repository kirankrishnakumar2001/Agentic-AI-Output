<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.com/cisco/bookings#"
     xml:base="http://example.com/cisco/bookings"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <owl:Ontology rdf:about="http://example.com/cisco/bookings">
        <rdfs:label>Cisco Bookings Enterprise Ontology</rdfs:label>
        <rdfs:comment>Enterprise OWL ontology generated from the Cisco bookings OSI semantic model, glossary, SQL star schema, and quote-to-booking business process documentation.</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>

    <owl:Class rdf:about="#BusinessDomain"><rdfs:label>Business Domain</rdfs:label></owl:Class>
    <owl:Class rdf:about="#BusinessEntity"><rdfs:label>Business Entity</rdfs:label></owl:Class>
    <owl:Class rdf:about="#BusinessProcessStep"><rdfs:label>Business Process Step</rdfs:label></owl:Class>
    <owl:Class rdf:about="#BusinessRole"><rdfs:label>Business Role</rdfs:label></owl:Class>

    <owl:Class rdf:about="#RevenueBookingsDomain"><rdfs:subClassOf rdf:resource="#BusinessDomain"/><rdfs:label>Revenue Bookings Domain</rdfs:label><rdfs:comment>Central transactional domain representing booked order lines and measurable outcomes.</rdfs:comment></owl:Class>
    <owl:Class rdf:about="#CustomerSalesDomain"><rdfs:subClassOf rdf:resource="#BusinessDomain"/><rdfs:label>Customer and Sales Domain</rdfs:label></owl:Class>
    <owl:Class rdf:about="#ProductPartnerDomain"><rdfs:subClassOf rdf:resource="#BusinessDomain"/><rdfs:label>Product and Partner Domain</rdfs:label></owl:Class>
    <owl:Class rdf:about="#TimeGeographyContractDomain"><rdfs:subClassOf rdf:resource="#BusinessDomain"/><rdfs:label>Time Geography and Contract Domain</rdfs:label></owl:Class>

    <owl:Class rdf:about="#Booking">
        <rdfs:subClassOf rdf:resource="#BusinessEntity"/>
        <rdfs:label>Booking</rdfs:label>
        <rdfs:comment>Represents a booked order line transaction.</rdfs:comment>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#occursOn"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#madeBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Customer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#referencesProduct"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Product"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#assignedToGeography"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Geography"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#ownedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#SalesRepresentative"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#governedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Contract"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#soldThrough"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="#Partner"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Date"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Date</rdfs:label><rdfs:comment>Date dimension used for calendar and fiscal analysis of bookings.</rdfs:comment></owl:Class>
    <owl:Class rdf:about="#Customer"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Customer</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Product"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Product</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Partner"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Partner</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Geography"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Geography</rdfs:label></owl:Class>
    <owl:Class rdf:about="#SalesRepresentative"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Sales Representative</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Contract"><rdfs:subClassOf rdf:resource="#BusinessEntity"/><rdfs:label>Contract</rdfs:label></owl:Class>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="#Date"/>
            <rdf:Description rdf:about="#Customer"/>
            <rdf:Description rdf:about="#Product"/>
            <rdf:Description rdf:about="#Partner"/>
            <rdf:Description rdf:about="#Geography"/>
            <rdf:Description rdf:about="#SalesRepresentative"/>
            <rdf:Description rdf:about="#Contract"/>
            <rdf:Description rdf:about="#Booking"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:Class rdf:about="#OpportunityQualification"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Opportunity Qualification</rdfs:label></owl:Class>
    <owl:Class rdf:about="#ConfigurePriceQuote"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Configure Price Quote</rdfs:label></owl:Class>
    <owl:Class rdf:about="#DealRegistration"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Deal Registration and Partner Routing</rdfs:label></owl:Class>
    <owl:Class rdf:about="#OrderPlacement"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Order Placement</rdfs:label></owl:Class>
    <owl:Class rdf:about="#BookingRecognition"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Booking Recognition</rdfs:label></owl:Class>
    <owl:Class rdf:about="#FulfillmentProvisioning"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Fulfillment and Provisioning</rdfs:label></owl:Class>
    <owl:Class rdf:about="#ContractEntitlementCreation"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Contract and Entitlement Creation</rdfs:label></owl:Class>
    <owl:Class rdf:about="#RenewalLifecycle"><rdfs:subClassOf rdf:resource="#BusinessProcessStep"/><rdfs:label>Renewal Lifecycle</rdfs:label></owl:Class>

    <owl:Class rdf:about="#SalesAccountExecutive"><rdfs:subClassOf rdf:resource="#BusinessRole"/><rdfs:label>Sales Account Executive</rdfs:label></owl:Class>
    <owl:Class rdf:about="#DealDesk"><rdfs:subClassOf rdf:resource="#BusinessRole"/><rdfs:label>Deal Desk</rdfs:label></owl:Class>
    <owl:Class rdf:about="#RevenueOperations"><rdfs:subClassOf rdf:resource="#BusinessRole"/><rdfs:label>Revenue Operations</rdfs:label></owl:Class>
    <owl:Class rdf:about="#ChannelPartnerOrganization"><rdfs:subClassOf rdf:resource="#BusinessRole"/><rdfs:label>Channel Partner Organization</rdfs:label></owl:Class>
    <owl:Class rdf:about="#CustomerExperienceRenewals"><rdfs:subClassOf rdf:resource="#BusinessRole"/><rdfs:label>Customer Experience Renewals</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Finance"><rdfs:subClassOf rdf:resource="#BusinessRole"/><rdfs:label>Finance</rdfs:label></owl:Class>

    <owl:ObjectProperty rdf:about="#occursOn">
        <rdfs:label>occurs on</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#Date"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#hasBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasBooking">
        <rdfs:label>has booking</rdfs:label>
        <rdfs:domain rdf:resource="#Date"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#madeBy">
        <rdfs:label>made by</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#Customer"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#makesBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#makesBooking">
        <rdfs:label>makes booking</rdfs:label>
        <rdfs:domain rdf:resource="#Customer"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#referencesProduct">
        <rdfs:label>references product</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#Product"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#appearsInBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#appearsInBooking">
        <rdfs:label>appears in booking</rdfs:label>
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#soldThrough">
        <rdfs:label>sold through</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#Partner"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#influencesBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#influencesBooking">
        <rdfs:label>influences booking</rdfs:label>
        <rdfs:domain rdf:resource="#Partner"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#assignedToGeography">
        <rdfs:label>assigned to geography</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#Geography"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#hasAssignedBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasAssignedBooking">
        <rdfs:label>has assigned booking</rdfs:label>
        <rdfs:domain rdf:resource="#Geography"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#ownedBy">
        <rdfs:label>owned by</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#SalesRepresentative"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#ownsBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#ownsBooking">
        <rdfs:label>owns booking</rdfs:label>
        <rdfs:domain rdf:resource="#SalesRepresentative"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#governedBy">
        <rdfs:label>governed by</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#Contract"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <owl:inverseOf rdf:resource="#governsBooking"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#governsBooking">
        <rdfs:label>governs booking</rdfs:label>
        <rdfs:domain rdf:resource="#Contract"/>
        <rdfs:range rdf:resource="#Booking"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#performsStep">
        <rdfs:label>performs step</rdfs:label>
        <rdfs:domain rdf:resource="#BusinessRole"/>
        <rdfs:range rdf:resource="#BusinessProcessStep"/>
        <owl:inverseOf rdf:resource="#performedBy"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#performedBy">
        <rdfs:label>performed by</rdfs:label>
        <rdfs:domain rdf:resource="#BusinessProcessStep"/>
        <rdfs:range rdf:resource="#BusinessRole"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#followsProcessStep">
        <rdfs:label>follows process step</rdfs:label>
        <rdfs:domain rdf:resource="#BusinessProcessStep"/>
        <rdfs:range rdf:resource="#BusinessProcessStep"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#producesBooking">
        <rdfs:label>produces booking</rdfs:label>
        <rdfs:domain rdf:resource="#BusinessProcessStep"/>
        <rdfs:range rdf:resource="#Booking"/>
        <owl:inverseOf rdf:resource="#producedByProcessStep"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#producedByProcessStep">
        <rdfs:label>produced by process step</rdfs:label>
        <rdfs:domain rdf:resource="#Booking"/>
        <rdfs:range rdf:resource="#BusinessProcessStep"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#createsContract">
        <rdfs:label>creates contract</rdfs:label>
        <rdfs:domain rdf:resource="#BusinessProcessStep"/>
        <rdfs:range rdf:resource="#Contract"/>
        <owl:inverseOf rdf:resource="#createdByProcessStep"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#createdByProcessStep">
        <rdfs:label>created by process step</rdfs:label>
        <rdfs:domain rdf:resource="#Contract"/>
        <rdfs:range rdf:resource="#BusinessProcessStep"/>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="#bookingId"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>booking id</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#orderNumber"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>order number</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#orderLineNumber"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>order line number</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#bookingType"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>booking type</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#isRenewal"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/><rdfs:label>is renewal</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#quantity"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>quantity</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#unitListPriceUsd"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/><rdfs:label>unit list price usd</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#discountPct"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/><rdfs:label>discount percentage</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#bookingAmountUsd"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/><rdfs:label>booking amount usd</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#acvUsd"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/><rdfs:label>acv usd</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#tcvUsd"><rdfs:domain rdf:resource="#Booking"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/><rdfs:label>tcv usd</rdfs:label></owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#dateKey"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>date key</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#fullDate"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/><rdfs:label>full date</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#dayOfWeek"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>day of week</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#monthName"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>month name</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#monthNumber"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>month number</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#calendarQuarter"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>calendar quarter</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#calendarYear"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>calendar year</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#fiscalYear"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>fiscal year</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#fiscalQuarter"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>fiscal quarter</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#fiscalPeriodSeq"><rdfs:domain rdf:resource="#Date"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>fiscal period sequence</rdfs:label></owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#customerKey"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>customer key</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#customerId"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>customer id</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#customerName"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>customer name</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#segment"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>segment</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#industry"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>industry</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#accountTier"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>account tier</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hqCountry"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>hq country</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hqRegion"><rdfs:domain rdf:resource="#Customer"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>hq region</rdfs:label></owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#productKey"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>product key</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#productId"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>product id</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#productName"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>product name</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#productFamily"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>product family</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#technologyDomain"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>technology domain</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#offerType"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>offer type</rdfs:label></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#businessEntity"><rdfs:domain rdf:resource="#Product"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>business entity</rdfs:label></owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#partnerKey"><rdfs:domain rdf:resource="#Partner"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/><rdfs:label>partner key</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#partnerId"><rdfs:domain rdf:resource="#Partner"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>partner id</rdfs:label><rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#partnerName"><rdfs:domain rdf:resource="#Partner"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/><rdfs:label>partner name</rdfs:label></owl:DatatypeProperty>
