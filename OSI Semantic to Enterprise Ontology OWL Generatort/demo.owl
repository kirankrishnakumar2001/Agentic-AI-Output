        <osi:performedBy rdf:resource="http://example.org/osi-cisco-bookings-ontology#CustomerExperienceRenewals"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#SalesAccountExecutive">
        <osi:performsActivity rdf:resource="http://example.org/osi-cisco-bookings-ontology#OpportunityQualification"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#DealDesk">
        <osi:performsActivity rdf:resource="http://example.org/osi-cisco-bookings-ontology#ConfigurePriceQuoteActivity"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#RevenueOperations">
        <osi:performsActivity rdf:resource="http://example.org/osi-cisco-bookings-ontology#BookingRecognitionActivity"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#ChannelPartnerOrganization">
        <osi:performsActivity rdf:resource="http://example.org/osi-cisco-bookings-ontology#DealRegistrationActivity"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#CustomerExperienceRenewals">
        <osi:performsActivity rdf:resource="http://example.org/osi-cisco-bookings-ontology#ContractEntitlementCreationActivity"/>
        <osi:performsActivity rdf:resource="http://example.org/osi-cisco-bookings-ontology#RenewalLifecycleActivity"/>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Booking">
        <rdfs:comment>Explicit source-supported measures are quantity, unitListPriceUsd, discountPct, bookingAmountUsd, acvUsd, and tcvUsd. Business rule note: for subscription and SaaS offers booking amount equals TCV and ACV is annualized; hardware is perpetual and ACV may be not applicable. These arithmetic and conditional rules are documented but not enforced as OWL axioms.</rdfs:comment>
    </rdf:Description>

    <rdf:Description rdf:about="http://example.org/osi-cisco-bookings-ontology#Date">
        <rdfs:comment>Glossary mentions day_of_week, month_number, and calendar_quarter, but they are absent from the physical schema and therefore excluded from asserted datatype properties.</rdfs:comment>
    </rdf:Description>

</rdf:RDF>
